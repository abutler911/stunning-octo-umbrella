# Twilio credentials — get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your verified Twilio phone number (E.164 format)
TWILIO_FROM_NUMBER=+15551234567

# Public URL where Twilio can reach your webhook server
# Use ngrok or similar for local dev: ngrok http 3000
PUBLIC_URL=https://your-ngrok-url.ngrok.io

# Port for the local Express server
PORT=3000
