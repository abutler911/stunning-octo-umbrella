# Twilio credentials — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Your verified Twilio phone number (E.164 format)
TWILIO_FROM_NUMBER=+15551234567

# Public URL where Twilio can reach your webhook server
# Use ngrok for local dev: ngrok http 3000
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# Anthropic API key — https://console.anthropic.com
# Required only for the "ai" persona (AI Edna)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port for the local Express server
PORT=3000
